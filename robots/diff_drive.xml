<mujoco model="diff_drive">
  <!--
    Differential-drive line-following robot — Hack Lab kit dimensions.
      Chassis : ~20 x 15 x 4 cm acrylic/plastic  (mass ~0.35 kg incl. electronics)
      Wheels  : TT geared DC motor wheels, radius 0.033 m, width 0.026 m
      Baseline: ~0.14 m (left-right wheel centre distance)
      Caster  : metal ball caster, front-centre  (passive)
    Drive: velocity-controlled rear wheels (actuator_velocity).
    Caster: free-spinning ball joint (no actuator).
    The floor plane and line strip are added programmatically via MjModel.
  -->

  <compiler angle="radian" autolimits="true"/>

  <!-- timestep 0.004 s = 250 Hz physics; 5 substeps per 50 Hz control tick -->
  <option timestep="0.004" gravity="0 0 -9.81" integrator="implicitfast">
  </option>

  <default>
    <joint damping="0.01" armature="0.001"/>
    <!-- Softer contacts prevent bounce/instability on the kit's light chassis -->
    <geom condim="3" friction="0.8 0.005 0.005"
          solimp="0.95 0.99 0.001 0.5 2"
          solref="0.04 1"/>
    <motor ctrllimited="true" ctrlrange="-18 18"/>
  </default>

  <worldbody>
    <!-- Ground plane: white, used for IR sensing -->
    <geom name="floor" type="plane" size="4 4 0.1" pos="0 0 0"
          rgba="0.96 0.96 0.96 1" condim="3" friction="0.8 0.005 0.005"
          solimp="0.95 0.99 0.001 0.5 2" solref="0.04 1"/>

    <!-- Line strip box (black): replaced each episode programmatically.
         Half-extents: [3.0, line_half_width, 0.0015]. Initially invisible. -->
    <geom name="line_strip" type="box" size="3.0 0.025 0.0015"
          pos="0 0 0.0015" rgba="0.03 0.03 0.03 1"
          contype="0" conaffinity="0"/>
    <!-- Segmented visual track geoms for sampled curves/arcs/turn sequences. -->
    <geom name="line_seg_000" type="box" size="0.001 0.001 0.001" pos="0 0 -5" rgba="0.03 0.03 0.03 0" contype="0" conaffinity="0"/>
