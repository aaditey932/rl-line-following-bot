    <geom name="line_seg_063" type="box" size="0.001 0.001 0.001" pos="0 0 -5" rgba="0.03 0.03 0.03 0" contype="0" conaffinity="0"/>

    <!-- Robot body — Hack Lab kit chassis dimensions -->
    <!-- Chassis ≈ 20x15x4 cm; wheels at rear, ball caster at front -->
    <!-- Spawn height: wheel radius (0.033) + small clearance = 0.038 m -->
    <body name="base_link" pos="0 0 0.05">
      <freejoint name="root"/>
      <!-- mass 0.35 kg: chassis + Pi + L298N + battery bank + 9V -->
      <inertial pos="0 0 0" mass="0.35"
                fullinertia="0.0025 0.0030 0.0045 0 0 0"/>
      <geom name="chassis" type="box" size="0.10 0.075 0.02"
            rgba="0.85 0.85 0.9 0.8" mass="0"/>

      <!-- IR sensor sites: 5 sensors under the front of chassis.
           Kit sensors typically 8–10 cm forward of wheel axle.
           Spaced 2 cm apart → 8 cm total span.
           z = -0.02 m (just below chassis floor, ~10 mm above ground). -->
      <site name="ir0" pos="0.08 -0.04 -0.018" size="0.004" rgba="1 0.4 0 1"/>
      <site name="ir1" pos="0.08 -0.02 -0.018" size="0.004" rgba="1 0.4 0 1"/>
      <site name="ir2" pos="0.08  0.00 -0.018" size="0.004" rgba="1 0.4 0 1"/>
      <site name="ir3" pos="0.08  0.02 -0.018" size="0.004" rgba="1 0.4 0 1"/>
      <site name="ir4" pos="0.08  0.04 -0.018" size="0.004" rgba="1 0.4 0 1"/>

      <!-- Left rear wheel: TT motor wheel radius=0.033m, width=0.026m -->
      <!-- Wheel axle offset: -0.07 m rear, ±0.07 m lateral -->
      <body name="left_rear_wheel" pos="-0.07 0.07 -0.017">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0" damping="0.03" armature="0.001"/>
        <inertial pos="0 0 0" mass="0.05"
                  fullinertia="0.000027 0.000054 0.000027 0 0 0"/>
        <geom name="left_wheel" type="cylinder" size="0.033 0.013"
              euler="1.5707963 0 0" rgba="0.9 0.75 0.1 1" mass="0"
              friction="1.2 0.01 0.01"/>
      </body>

      <!-- Right rear wheel -->
      <body name="right_rear_wheel" pos="-0.07 -0.07 -0.017">
        <joint name="right_wheel_joint" type="hinge" axis="0 1 0" damping="0.03" armature="0.001"/>
        <inertial pos="0 0 0" mass="0.05"
                  fullinertia="0.000027 0.000054 0.000027 0 0 0"/>
        <geom name="right_wheel" type="cylinder" size="0.033 0.013"
              euler="1.5707963 0 0" rgba="0.9 0.75 0.1 1" mass="0"
              friction="1.2 0.01 0.01"/>
      </body>

      <!-- Front ball caster — metal ball, radius ~15 mm -->
      <body name="front_caster" pos="0.08 0 -0.02">
        <joint name="caster_joint" type="ball" damping="0.002" armature="0"/>
        <inertial pos="0 0 0" mass="0.02"
                  fullinertia="0.000003 0.000003 0.000003 0 0 0"/>
        <geom name="caster_geom" type="sphere" size="0.015"
              rgba="0.6 0.6 0.6 1" mass="0"
              friction="0.01 0.001 0.001"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Velocity actuators.  TT motors at 9V ≈ 200 RPM ≈ 21 rad/s at wheel. -->
    <!-- ctrlrange ±18 rad/s is a conservative usable range. -->
    <velocity name="left_wheel_vel"  joint="left_wheel_joint"
              kv="6" ctrlrange="-18 18"/>
    <velocity name="right_wheel_vel" joint="right_wheel_joint"
              kv="6" ctrlrange="-18 18"/>
  </actuator>

  <sensor>
    <!-- Joint velocity sensors for wheel odometry (encoder analogue) -->
    <jointvel name="left_wheel_vel_sensor"  joint="left_wheel_joint"/>
    <jointvel name="right_wheel_vel_sensor" joint="right_wheel_joint"/>
    <!-- Body velocity in world frame (for forward-speed reward) -->
    <framelinvel name="base_linvel" objtype="body" objname="base_link"/>
    <framequat    name="base_quat"  objtype="body" objname="base_link"/>
  </sensor>
</mujoco>
