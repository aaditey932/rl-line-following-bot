<?xml version="1.0"?>
<!-- Rear differential drive (left/right driven); single passive front caster (ball). -->
<robot name="diff_drive">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.012" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.022"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.26 0.22 0.06"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.26 0.22 0.06"/>
      </geometry>
    </collision>
  </link>

  <link name="front_caster">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_caster_joint" type="continuous">
    <origin xyz="0.11 0 -0.02" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_caster"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="left_rear_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.14"/>
      <inertia ixx="0.00014" ixy="0" ixz="0" iyy="0.00028" iyz="0" izz="0.00014"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_rear_wheel_joint" type="continuous">
    <origin xyz="-0.11 0.11 -0.02" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_rear_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_rear_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.14"/>
      <inertia ixx="0.00014" ixy="0" ixz="0" iyy="0.00028" iyz="0" izz="0.00014"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_rear_wheel_joint" type="continuous">
    <origin xyz="-0.11 -0.11 -0.02" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_rear_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>
</robot>
